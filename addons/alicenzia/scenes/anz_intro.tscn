[node name="Label4" type="Label" parent="PanelContainer/MarginContainer/VBoxContainer/GuideTab/Autofill License/ScrollContainer/VBoxContainer"]
custom_minimum_size = Vector2(400, 0)
layout_mode = 2
text = "Currently supported licenses are 0BSD, Apache-2.0, CC0-1.0, CC-BY-4.0, and MIT."
