[node name="Label" type="Label" parent="PanelContainer/MarginContainer/VBoxContainer/GuideTab/When To Use/ScrollContainer/VBoxContainer"]
custom_minimum_size = Vector2(400, 0)
layout_mode = 2
text = "Now when should you use this feature? Well everytime you downloaded free assets for your project, or installed a new  addon from the Asset Library, you can fill the license data so that it'll be easier to manage and credit those external assets in the future."
label_settings = ExtResource("1_3isa3")
autowrap_mode = 3

[node name="Label3" type="Label" parent="PanelContainer/MarginContainer/VBoxContainer/GuideTab/When To Use/ScrollContainer/VBoxContainer"]
custom_minimum_size = Vector2(400, 0)
layout_mode = 2
text = "For example, you just downloaded the Phantom Camera addon. To add its license data, just select the phantom-camera folder and fill the data. Everything inside the phantom-camera folder (recursively) will automatically be covered by the same license data."
label_settings = ExtResource("1_3isa3")
autowrap_mode = 3

