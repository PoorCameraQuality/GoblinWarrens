[node name="ScrollContainer" type="ScrollContainer" parent="PanelContainer/MarginContainer/VBoxContainer/GuideTab/License Data Tips"]
layout_mode = 2
size_flags_horizontal = 3

[node name="VBoxContainer" type="VBoxContainer" parent="PanelContainer/MarginContainer/VBoxContainer/GuideTab/License Data Tips/ScrollContainer"]
layout_mode = 2

[node name="Label" type="Label" parent="PanelContainer/MarginContainer/VBoxContainer/GuideTab/License Data Tips/ScrollContainer/VBoxContainer"]
custom_minimum_size = Vector2(400, 0)
layout_mode = 2
text = "Here's a guide on how to fill the license data for each property."
label_settings = ExtResource("1_3isa3")
autowrap_mode = 3

[node name="RichTextLabel" type="RichTextLabel" parent="PanelContainer/MarginContainer/VBoxContainer/GuideTab/License Data Tips/ScrollContainer/VBoxContainer"]
layout_mode = 2
bbcode_enabled = true
text = "[ul bullet=• ]
[u]Name[/u] : The name of the asset. The asigned name could be different than the file name. Using Title Case is recommended but not required.
[u]Type[/u] : The type of the asset, is it a sprite, an addon, a font, etc. Helpful to organize and separate assets from each others.
[u]Ownership Type[/u] : Is it an asset you/your team made, or is it an asset you got somewhere else (from the internet, commisioned someone to made it, etc.)
[u]Creator[/u] : The asset creator's name. Could be the author name from the license text or their online/account alias.
[u]License Type[/u] : The license type, if it uses popular open source license. Use _Custom if the owner provides a custom license. Use _NotProper if the owner provides/write the terms of use of said license, but not technically written as a license. Use All Rights Reserved otherwise.
[u]Usage[/u] : In what way do you use said asset on your project. Optional to fill.
[u]Modification[/u] : Any modification you did to the asset, if there any. Optional to fill.
[u]Webpage Link[/u] : The website link in which you get the assets from, if it was acquired from the internet.
[u]Full License[/u] : A copy of the full license text. Optional to fill.
[/ul]"
fit_content = true

