{
  "mcpServers": {
    "godot-runtime-bridge": {
      "command": "node",
      "args": ["C:/Tools/godot-runtime-bridge/mcp/index.js"],
      "env": {
        "GODOT_PATH": "C:/Path/To/Godot_v4.7-stable_win64.exe",
        "GODOT_CONSOLE_PATH": "C:/Path/To/Godot_v4.7-stable_win64_console.exe",
        "GRB_PROJECT_PATH": "E:/Projects/goblin-colony"
      }
    }
  }
}
